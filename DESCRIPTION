Package: GOcontext
Type: Package
Title: Context-Aware GO Subgraph Construction for Enrichment
Version: 0.1.0
Authors@R: c(
    person(
      given = "Thomas",
      family = "Rauter",
      email = "rauterthomas0@gmail.com",
      role = c("aut", "cre", "fnd"),
      comment = c(ORCID = "0009-0004-5578-3628")
